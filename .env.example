# ============================================================
# 环境变量示例。使用方法：
#   1. 复制本文件为 .env.local
#   2. 填入你自己的 Supabase 与（可选）AI 配置
#   3. 重启 npm run dev
# ------------------------------------------------------------
# ⚠️ VITE_ 开头的变量会打包进前端，anon key 是公开密钥，放前端安全，
#    真正的数据安全由 Supabase 的 RLS 行级安全策略保证。
# ============================================================

# —— Supabase（必填，用于账号登录 + 云端图鉴同步）——
# 在 Supabase 项目的 Settings → API 页面获取
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# —— AI 自然向导（可选，留空则用内置离线问答）——
# 任意 OpenAI 兼容接口
VITE_AI_BASE_URL=
VITE_AI_API_KEY=
VITE_AI_MODEL=gpt-4o-mini
